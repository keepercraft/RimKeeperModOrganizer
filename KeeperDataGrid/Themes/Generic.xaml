<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:KeeperDataGrid">

    <Style TargetType="{x:Type local:AdvancedFilterDataGrid}" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Top"/>
                    <!--<EventSetter Event="PreviewMouseRightButtonUp" Handler="Header_PreviewMouseRightButtonUp"/>-->
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <Grid Margin="4,2" x:Name="HeaderGrid" Height="40" VerticalAlignment="Top" >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding}" FontWeight="Bold"/>
                                    <TextBox Grid.Row="1" x:Name="FilterTextBox"
                                         Visibility="{Binding Column.ShowFilter, 
                                            RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, 
                                            UpdateSourceTrigger=PropertyChanged}"
                                         Text="{Binding Column.FilterValue, 
                                            RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, 
                                            Delay=500,
                                            UpdateSourceTrigger=PropertyChanged}"
                                         Height="22" 
                                         Margin="0,2,0,2"
                                         HorizontalAlignment="Stretch"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter TargetName="HeaderGrid" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
