<Window x:Class="RimKeeperModOrganizerWPF.Views.ModDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RimKeeperModOrganizerWPF.Views"
        xmlns:sdl="http://schemas.sdl.com/xaml"
        mc:Ignorable="d"
        Title="{Binding SelectedMod.Label}" Height="750" Width="500">
    <Grid Background="{Binding SelectedMod.Data.Color}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Open in Steam"
              ToolTip="{Binding SelectedMod.SteamLink}"
              Command="{Binding OpenSteamLinkCommand}"
              CommandParameter="{Binding SelectedMod.SteamLink}" />
            <MenuItem Header="Open in Explorer"
              ToolTip="{Binding SelectedMod.Path}"
              Command="{Binding OpenLinkCommand}"
              CommandParameter="{Binding SelectedMod.Path}" />
            <MenuItem Header="Change color"
              ToolTip="{Binding SelectedMod.Data.Color}"
              Command="{Binding ChangeColorCommand}"
              CommandParameter="{Binding SelectedMod}" />
        </Menu>

        <ScrollViewer Grid.Row="1" Padding="10" Background="White" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="Padding" Value="3"/>
                        <Setter Property="IsReadOnly" Value="True"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
                    </Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Margin" Value="0,0,0,0"/>
                        <Setter Property="Padding" Value="3"/>
                        <Setter Property="Width" Value="150"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="TextAlignment" Value="Right"/>
                    </Style>
                </StackPanel.Resources>

                <Image Source="{Binding SelectedMod.ThumbnailPath}" Stretch="Uniform" MaxHeight="300" Margin="0,0,0,3"/>

                <DockPanel >
                    <TextBlock Width="80" Text="Groups:"/>
                    <sdl:MultiSelectComboBox 
                        x:Name="MyMultiSelect"
                        ItemsSource="{Binding ModGroups}"
                        SelectedItems="{Binding SelectedMod.Data.Groups, Mode=TwoWay}"
                        KeyDown="MultiSelect_KeyDown"
                        IsEditable="True"
                        EnableFiltering="True"
                        SelectionMode="Multiple">
                    </sdl:MultiSelectComboBox>
                </DockPanel>
                <DockPanel >
                    <TextBlock Width="80" Text="Comment:"/>
                    <TextBox Text="{Binding SelectedMod.Data.Comment, Mode=TwoWay}" 
                         IsReadOnly="False"    
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Top"
                         BorderBrush="Gray"
                         BorderThickness="1"
                         Padding="5"/>
                </DockPanel>


                <DockPanel >
                    <TextBlock Text="Name:"/>
                    <TextBox Text="{Binding SelectedMod.About.Name,Mode=OneWay}"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="Author:"/>
                    <TextBox Text="{Binding SelectedMod.About.Author,Mode=OneWay}"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="Url:"/>
                    <TextBox Text="{Binding SelectedMod.About.Url,Mode=OneWay}" Cursor="Hand">
                        <TextBox.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                Command="{Binding OpenLinkCommand}"
                                CommandParameter="{Binding SelectedMod.About.Url}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="Package ID:"/>
                    <TextBox Text="{Binding SelectedMod.About.PackageId,Mode=OneWay}"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="Steam Published ID:"/>
                    <TextBox Text="{Binding SelectedMod.About.SteamId,Mode=OneWay}"/>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="SupportedVersions:"/>
                    <TextBox Text="{Binding SelectedMod.Versions,Mode=OneWay}"/>
                </DockPanel>
                <!--<DockPanel>
                    <TextBlock Padding="3" Width="150" Text="SupportedVersions:" FontWeight="Bold" TextAlignment="Right"/>
                    <ItemsControl ItemsSource="{Binding SelectedMod.About.SupportedVersions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Padding="3" IsReadOnly="True" Text="{Binding Mode=OneWay}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>-->

                <DockPanel>
                    <TextBlock Text="ModDependencies:"/>
                    <ItemsControl ItemsSource="{Binding SelectedMod.About.ModDependencies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding DisplayName, StringFormat=• {0}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="LoadAfter:"/>
                    <ItemsControl ItemsSource="{Binding SelectedMod.About.LoadAfter}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ., StringFormat=• {0}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="LoadBefore:"/>
                    <ItemsControl ItemsSource="{Binding SelectedMod.About.LoadBefore}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ., StringFormat=• {0}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
                <DockPanel>
                    <TextBlock  Text="IncompatibleWith:"/>
                    <ItemsControl ItemsSource="{Binding SelectedMod.About.IncompatibleWith}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ., StringFormat=• {0}}" Foreground="Red"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>

                <DockPanel>
                    <TextBlock Text="Description:"/>
                    <TextBox Text="{Binding SelectedMod.About.Description}" TextWrapping="Wrap"/>
                </DockPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>