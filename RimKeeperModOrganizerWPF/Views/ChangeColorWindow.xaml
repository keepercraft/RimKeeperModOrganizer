<Window x:Class="RimKeeperModOrganizerWPF.Views.ChangeColorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RimKeeperModOrganizerWPF.Views" 
        xmlns:cp="clr-namespace:ColorPicker;assembly=ColorPicker"
        Title="Wybierz kolor"
        Width="420"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <cp:StandardColorPicker SelectedColor="{Binding Data.Color, Mode=TwoWay}" Grid.Row="0"/>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Clear"
                    Width="80"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="Clear_Click"/>
            <Button Content="OK"
                    Width="80"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="Ok_Click"/>
            <Button Content="Anuluj"
                    Width="80"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
