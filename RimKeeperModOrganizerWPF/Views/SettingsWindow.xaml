<Window x:Class="RimKeeperModOrganizerWPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RimKeeperModOrganizerWPF.Views"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="5" BorderBrush="Gray" BorderThickness="2">
            <ScrollViewer>
                <StackPanel Margin="5" VerticalAlignment="Top">

                    <GroupBox Header="PathSettings">
                        <TextBox Text="{Binding Data.PathSettings, Mode=TwoWay}" />
                    </GroupBox>

                    <GroupBox Header="PathModData">
                        <TextBox Text="{Binding Data.PathModData, Mode=TwoWay}" />
                    </GroupBox>


                    <GroupBox Header="PathDirGame">
                        <TextBox Text="{Binding Data.PathDirGame, Mode=TwoWay}" />
                    </GroupBox>

                    <GroupBox Header="PathDirGameConfig">
                        <TextBox Text="{Binding Data.PathDirGameConfig, Mode=TwoWay}" />
                    </GroupBox>

                    <GroupBox Header="PathDirModsSteam">
                        <TextBox Text="{Binding Data.PathDirModsSteam, Mode=TwoWay}" />
                    </GroupBox>

                    <GroupBox Header="PathDirModsLocal">
                        <TextBox Text="{Binding Data.PathDirModsLocal, Mode=TwoWay}" />
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Width="100" Margin="5" Command="{Binding SaveCommand}">Ok</Button>
            <Button Width="100" Margin="5" Command="{Binding CancelCommand}">Cancel</Button>
        </DockPanel>
    </Grid>
</Window>
