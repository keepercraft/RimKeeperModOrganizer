<Window x:Class="RimKeeperModOrganizerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RimKeeperModOrganizerWPF"
        xmlns:vc="clr-namespace:RimKeeperModOrganizerWPF.Views.ValueConverter"
        xmlns:ex="clr-namespace:RimKeeperModOrganizerWPF.Views.Extensions"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"      
        mc:Ignorable="d"
        xmlns:kdg="clr-namespace:KeeperDataGrid;assembly=KeeperDataGrid" 
        xmlns:sdl="http://schemas.sdl.com/xaml"
        Title="RimKeeper - ModOrganizer" 
        Height="{Binding MainWidowSettings.Height, Mode=TwoWay}" 
        Width="{Binding MainWidowSettings.Width, Mode=TwoWay}"
        Left="{Binding MainWidowSettings.Left, Mode=TwoWay}"
        Top="{Binding MainWidowSettings.Top, Mode=TwoWay}"
        >
    <Window.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DataGridStyles.xaml"/>
                <ResourceDictionary Source="/Themes/MultiDragStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <ex:CustomDragSource x:Key="CustomDragSource"/>
            <vc:BoolToSLRConverter x:Key="BoolToSLRConverter"/>
            <ex:BindingProxy x:Key="Proxy" Data="{Binding}" />
            <vc:DoubleToDataGridLengthConverter x:Key="DoubleToLengthConverter" />
            <vc:GridLengthConverter x:Key="GridLengthConverter" />
            <BooleanToVisibilityConverter x:Key="BoolVis"/>

            <ContextMenu x:Key="DataGridContextMenu" 
                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Header="Open folder" 
                  Command="{Binding OpenLinkCommand}" 
                  CommandParameter="{Binding PlacementTarget.SelectedItem.Path, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                <MenuItem Header="Open browser" 
                  Command="{Binding OpenLinkCommand}" 
                  CommandParameter="{Binding PlacementTarget.SelectedItem.SteamLink, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                <MenuItem Header="Open Steam" 
                  Command="{Binding OpenSteamLinkCommand}" 
                  CommandParameter="{Binding PlacementTarget.SelectedItem.SteamLink, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                <Separator />
                <MenuItem Header="Change Color" 
                  Command="{Binding ChangeColorCommand}" 
                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                <MenuItem Header="Remove Data" 
                  Command="{Binding ModDataRemoveCommand}" 
                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                <MenuItem Header="Details" 
                  Command="{Binding ModDetailCommand}" 
                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            </ContextMenu>

        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding MainWidowSettings.DetailPanelWidth, Converter={StaticResource GridLengthConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="{Binding MainWidowSettings.ConfigModPanelWidth, Converter={StaticResource GridLengthConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GridSplitter Grid.Column="1" Grid.Row="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Gray"
                      ShowsPreview="True"/>
        <GridSplitter Grid.Column="3" Grid.Row="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Gray"
                      ShowsPreview="True"/>

        <StatusBar Grid.Row="2" Grid.ColumnSpan="5"></StatusBar>

        <Menu Grid.Row="0" Grid.ColumnSpan="4" IsEnabled="{Binding IsUIListEnabled}">
            <MenuItem Header="Refresh" Command="{Binding RefreshCommand}"/>
            <MenuItem Header="Mods Config">
                <MenuItem Header="Save" Command="{Binding SaveCommand}"/>
                <Separator/>
                <MenuItem Header="Import" Command="{Binding LoadConfigCommand}"/>
                <MenuItem Header="Export" Command="{Binding SaveConfigCommand}"/>
                <Separator/>
                <MenuItem Header="Export all mods to CSV" Command="{Binding ModsToCSVCommand}"/>
            </MenuItem>
            <MenuItem Header="Actions">
                <MenuItem Header="Change Mod Color" Command="{Binding ChangeColorCommand}"/>
                <MenuItem Header="Mod Details" Command="{Binding ModDetailCommand}" CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Rimpy Colors Load" Command="{Binding RimpyColorLoadCommand}"/>
                <Separator/>
                <MenuItem Header="Options" Command="{Binding OptionsCommand}"/>
            </MenuItem>
            <MenuItem Header="[Test]" Command="{Binding TestCommand}"/>
        </Menu>
        <Menu Grid.Row="0" Grid.Column="5">
            <MenuItem Header="{Binding GetModConfigStaticLable}" Background="{Binding GetModConfigStaticColor}">
                <MenuItem.ToolTip>
                    <ToolTip>
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ListModsConfigAlert}"/>
                        </ScrollViewer>
                    </ToolTip>
                </MenuItem.ToolTip>
            </MenuItem>
        </Menu>
        <!--<ToolBar Grid.Row="0" Grid.ColumnSpan="5">
            <Button Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="Import" Command="{Binding LoadConfigCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="Export" Command="{Binding SaveConfigCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="Options" Command="{Binding OptionsCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="ChangeColor" Command="{Binding ChangeColorCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="[RimpyLoad]" Command="{Binding RimpyColorLoadCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="[CSV]" Command="{Binding ModsToCSVCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
            <Button Content="[TEST]" Command="{Binding TestCommand}" IsEnabled="{Binding IsUIListEnabled}"/>
